import os

# Paths
OUTPUT_DIR      = '/kaggle/working'
MODEL_SAVE_PATH = '/kaggle/working/plant_disease_model.keras'
NAMES_SAVE_PATH = '/kaggle/working/class_names.json'
CKPT_DIR        = '/kaggle/working/checkpoints'
os.makedirs(CKPT_DIR, exist_ok=True)

# Dataset path (already mounted in Kaggle)
IMAGES_ROOT = '/kaggle/input/datasets/abdallahalidev/plantvillage-dataset/plantvillage dataset/color'

# If the path above does not work, uncomment to auto-find:
# for root, dirs, _ in os.walk('/kaggle/input'):
#     if len(dirs) > 20:
#         IMAGES_ROOT = root
#         break

print('Images exist :', os.path.exists(IMAGES_ROOT))
print('Classes found:', len(os.listdir(IMAGES_ROOT)) if os.path.exists(IMAGES_ROOT) else 'PATH NOT FOUND')

# Model / image
IMG_SIZE    = (224, 224)   # EfficientNetV2B3 native — must match app.py
BATCH_SIZE  = 32           # lower to 16 if OOM
NUM_CLASSES = 38           # PlantVillage standard split

# Training schedule
PHASE1_EPOCHS = 15         # backbone frozen  (head warm-up)
PHASE2_EPOCHS = 25         # top-50 layers unfrozen (fine-tune)
PHASE3_EPOCHS = 10         # full model, very low LR

PHASE1_LR = 1e-3
PHASE2_LR = 5e-5
PHASE3_LR = 1e-5

SEED       = 42
VAL_SPLIT  = 0.15
TEST_SPLIT = 0.10          # held-out set for final evaluation

print('Config loaded ✓')





import json
import numpy as np
from tensorflow.keras.utils import image_dataset_from_directory

train_ds = image_dataset_from_directory(
    IMAGES_ROOT,
    validation_split = VAL_SPLIT + TEST_SPLIT,
    subset           = 'training',
    seed             = SEED,
    image_size       = IMG_SIZE,
    batch_size       = BATCH_SIZE,
    label_mode       = 'categorical',
    shuffle          = True,
)

val_test_ds = image_dataset_from_directory(
    IMAGES_ROOT,
    validation_split = VAL_SPLIT + TEST_SPLIT,
    subset           = 'validation',
    seed             = SEED,
    image_size       = IMG_SIZE,
    batch_size       = BATCH_SIZE,
    label_mode       = 'categorical',
    shuffle          = False,
)

CLASS_NAMES = train_ds.class_names
NUM_CLASSES = len(CLASS_NAMES)
print(f'Classes: {NUM_CLASSES}  |  Train batches: {len(train_ds)}')

# Save class_names.json immediately (must match training order)
with open(NAMES_SAVE_PATH, 'w') as fh:
    json.dump(CLASS_NAMES, fh, indent=2)
print('class_names.json saved ->', NAMES_SAVE_PATH)

# Split val_test -> val 75% / test 25%
total_val_test = len(val_test_ds)
val_batches    = int(total_val_test * 0.75)
val_ds         = val_test_ds.take(val_batches)
test_ds        = val_test_ds.skip(val_batches)

print(f'Val batches: {val_batches}  |  Test batches: {total_val_test - val_batches}')


# Augmentation + pipeline optimisation
AUTOTUNE = tf.data.AUTOTUNE

data_augmentation = tf.keras.Sequential([
    tf.keras.layers.RandomFlip('horizontal_and_vertical'),
    tf.keras.layers.RandomRotation(0.15),
    tf.keras.layers.RandomZoom(0.1),
    tf.keras.layers.RandomContrast(0.15),
    tf.keras.layers.RandomBrightness(0.10),
    tf.keras.layers.RandomTranslation(0.05, 0.05),
], name='augmentation')

def prepare_train(ds):
    return (
        ds
                                                 # cache images in RAM after first epoch
        .map(lambda x, y: (data_augmentation(x, training=True), y),
             num_parallel_calls=AUTOTUNE)
        .prefetch(AUTOTUNE)                              # overlap CPU/GPU work
    )

def prepare_eval(ds):
    return ds.prefetch(AUTOTUNE)                 # val/test never change

train_ds_aug = prepare_train(train_ds)
val_ds_prep  = prepare_eval(val_ds)
test_ds_prep = prepare_eval(test_ds)

print('Data pipelines ready ✓')





from tensorflow.keras import layers, Model

def build_model(num_classes, img_size=(224, 224), dropout_rate=0.3):
    inputs = layers.Input(shape=(*img_size, 3), name='image_input')

    # Rescaling inside model so .keras file is self-contained
    x = layers.Rescaling(1.0 / 255.0, name='rescaling_input')(inputs)

    # Backbone
    backbone = tf.keras.applications.EfficientNetV2B3(
        include_top           = False,
        weights               = 'imagenet',
        input_tensor          = x,
        pooling               = None,
        include_preprocessing = False,   # we handle rescaling above
    )
    backbone.trainable = False           # frozen in Phase 1

    # Classification head
    x = backbone.output
    x = layers.GlobalAveragePooling2D(name='gap')(x)
    x = layers.BatchNormalization(name='bn_head')(x)
    x = layers.Dropout(dropout_rate, name='dropout')(x)
    x = layers.Dense(512, activation='relu', name='fc_512')(x)
    x = layers.Dropout(dropout_rate / 2, name='dropout2')(x)
    outputs = layers.Dense(num_classes, activation='softmax', name='predictions')(x)

    model = Model(inputs=inputs, outputs=outputs, name='LeafScan_EfficientNetV2B3')
    return model, backbone

model, backbone = build_model(NUM_CLASSES)
model.summary(line_length=100, show_trainable=True)





from tensorflow.keras import callbacks as cb

def make_callbacks(phase, lr):
    ckpt_path = os.path.join(CKPT_DIR, f'phase{phase}_best.weights.h5')
    return [
        cb.ModelCheckpoint(
            filepath          = ckpt_path,
            monitor           = 'val_accuracy',
            save_best_only    = True,
            save_weights_only = True,
            verbose           = 1,
        ),
        cb.EarlyStopping(
            monitor              = 'val_accuracy',
            patience             = 7,
            restore_best_weights = True,
            verbose              = 1,
        ),
        cb.ReduceLROnPlateau(
            monitor  = 'val_loss',
            factor   = 0.4,
            patience = 3,
            min_lr   = 1e-7,
            verbose  = 1,
        ),
        cb.TensorBoard(
            log_dir        = os.path.join(CKPT_DIR, f'logs_phase{phase}'),
            histogram_freq = 0,
        ),
        cb.CSVLogger(
            os.path.join(CKPT_DIR, f'phase{phase}_history.csv'), append=False
        ),
    ]

print('Callbacks factory ready ✓')





backbone.trainable = False

model.compile(
    optimizer = tf.keras.optimizers.Adam(PHASE1_LR),
    loss      = 'categorical_crossentropy',
    metrics   = ['accuracy', tf.keras.metrics.TopKCategoricalAccuracy(k=3, name='top3_acc')],
)

print(f'Trainable params: {sum(w.numpy().size for w in model.trainable_weights):,}')
print(f'Phase 1: {PHASE1_EPOCHS} epochs  |  LR = {PHASE1_LR}')

hist1 = model.fit(
    train_ds_aug,
    epochs          = PHASE1_EPOCHS,
    validation_data = val_ds_prep,
    callbacks       = make_callbacks(1, PHASE1_LR),
)





backbone.trainable = True
UNFREEZE_FROM = len(backbone.layers) - 50

for i, layer in enumerate(backbone.layers):
    layer.trainable = (i >= UNFREEZE_FROM)
    if isinstance(layer, tf.keras.layers.BatchNormalization):
        layer.trainable = False   # keep BN frozen for stability

trainable_now = sum(1 for l in backbone.layers if l.trainable)
print(f'Backbone layers unfrozen: {trainable_now} / {len(backbone.layers)}')

model.compile(
    optimizer = tf.keras.optimizers.Adam(PHASE2_LR),
    loss      = 'categorical_crossentropy',
    metrics   = ['accuracy', tf.keras.metrics.TopKCategoricalAccuracy(k=3, name='top3_acc')],
)

print(f'Phase 2: {PHASE2_EPOCHS} epochs  |  LR = {PHASE2_LR}')

hist2 = model.fit(
    train_ds_aug,
    epochs          = PHASE1_EPOCHS + PHASE2_EPOCHS,
    initial_epoch   = PHASE1_EPOCHS,
    validation_data = val_ds_prep,
    callbacks       = make_callbacks(2, PHASE2_LR),
)





backbone.trainable = True
for layer in backbone.layers:
    if isinstance(layer, tf.keras.layers.BatchNormalization):
        layer.trainable = False   # keep BN frozen

model.compile(
    optimizer = tf.keras.optimizers.Adam(PHASE3_LR),
    loss      = tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.05),
    metrics   = ['accuracy', tf.keras.metrics.TopKCategoricalAccuracy(k=3, name='top3_acc')],
)

total_epochs = PHASE1_EPOCHS + PHASE2_EPOCHS + PHASE3_EPOCHS
print(f'Phase 3: {PHASE3_EPOCHS} epochs  |  LR = {PHASE3_LR}')

hist3 = model.fit(
    train_ds_aug,
    epochs          = total_epochs,
    initial_epoch   = PHASE1_EPOCHS + PHASE2_EPOCHS,
    validation_data = val_ds_prep,
    callbacks       = make_callbacks(3, PHASE3_LR),
)





import matplotlib.pyplot as plt

def merge_history(*hists):
    merged = {}
    for h in hists:
        for k, v in h.history.items():
            merged.setdefault(k, []).extend(v)
    return merged

history      = merge_history(hist1, hist2, hist3)
epochs_range = range(1, len(history['accuracy']) + 1)

fig, axes = plt.subplots(1, 3, figsize=(18, 5))
fig.suptitle('LeafScan AI — EfficientNetV2B3 Training Curves', fontsize=14, fontweight='bold')

# Accuracy
ax = axes[0]
ax.plot(epochs_range, history['accuracy'],     label='Train Acc',  color='#5cb85c')
ax.plot(epochs_range, history['val_accuracy'], label='Val Acc',    color='#a8e6a3', linestyle='--')
ax.axvline(PHASE1_EPOCHS, color='gray', linestyle=':', alpha=0.6, label='Phase 2 start')
ax.axvline(PHASE1_EPOCHS + PHASE2_EPOCHS, color='orange', linestyle=':', alpha=0.6, label='Phase 3 start')
ax.set_title('Accuracy'); ax.set_xlabel('Epoch'); ax.legend(); ax.grid(True, alpha=0.3)

# Loss
ax = axes[1]
ax.plot(epochs_range, history['loss'],     label='Train Loss', color='#e87a4b')
ax.plot(epochs_range, history['val_loss'], label='Val Loss',   color='#f0c090', linestyle='--')
ax.axvline(PHASE1_EPOCHS, color='gray', linestyle=':', alpha=0.6)
ax.axvline(PHASE1_EPOCHS + PHASE2_EPOCHS, color='orange', linestyle=':', alpha=0.6)
ax.set_title('Loss'); ax.set_xlabel('Epoch'); ax.legend(); ax.grid(True, alpha=0.3)

# Top-3 Accuracy
ax = axes[2]
ax.plot(epochs_range, history['top3_acc'],     label='Train Top-3', color='#89c4e1')
ax.plot(epochs_range, history['val_top3_acc'], label='Val Top-3',   color='#c0e8f8', linestyle='--')
ax.axvline(PHASE1_EPOCHS, color='gray', linestyle=':', alpha=0.6)
ax.axvline(PHASE1_EPOCHS + PHASE2_EPOCHS, color='orange', linestyle=':', alpha=0.6)
ax.set_title('Top-3 Accuracy'); ax.set_xlabel('Epoch'); ax.legend(); ax.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'training_curves.png'), dpi=150, bbox_inches='tight')
plt.show()
print('Curves saved ✓')





print('=' * 60)
print('Final test-set evaluation')
print('=' * 60)

results      = model.evaluate(test_ds_prep, verbose=1)
metric_names = model.metrics_names

for name, val in zip(metric_names, results):
    print(f'  {name:20s}: {val:.4f}')





import numpy as np
from sklearn.metrics import classification_report, confusion_matrix
import seaborn as sns

# Fast prediction — single call for entire test set
print('Running predictions...')
y_pred_probs = model.predict(test_ds_prep, verbose=1)
y_pred = np.argmax(y_pred_probs, axis=1)

# Collect true labels
y_true = np.concatenate([
    np.argmax(labels.numpy(), axis=1)
    for _, labels in test_ds_prep
])

# Only use classes that appear in test set
present_labels = sorted(set(y_true) | set(y_pred))
present_names  = [CLASS_NAMES[i] for i in present_labels]

print('\nClassification Report:')
print(classification_report(
    y_true, y_pred,
    labels       = present_labels,
    target_names = present_names,
    digits       = 3
))

# Confusion matrix
cm = confusion_matrix(y_true, y_pred, labels=present_labels, normalize='true')
fig, ax = plt.subplots(figsize=(14, 12))
sns.heatmap(cm, annot=True, fmt='.2f', cmap='Greens',
            xticklabels=present_names,
            yticklabels=present_names,
            linewidths=0.3, ax=ax)
ax.set_title(f'Confusion Matrix — {len(present_labels)} classes in test set', fontsize=14)
ax.set_xlabel('Predicted'); ax.set_ylabel('True')
plt.xticks(rotation=90, fontsize=8)
plt.yticks(rotation=0,  fontsize=8)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'confusion_matrix.png'), dpi=150, bbox_inches='tight')
plt.show()
print(f'Confusion matrix saved  ({len(present_labels)} classes shown)')





