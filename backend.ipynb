# SavedModel format
SAVED_MODEL_DIR = os.path.join(OUTPUT_DIR, 'saved_model')
model.export(SAVED_MODEL_DIR)
print('SavedModel exported ->', SAVED_MODEL_DIR)

# TFLite with dynamic range quantization
converter = tf.lite.TFLiteConverter.from_saved_model(SAVED_MODEL_DIR)
converter.optimizations = [tf.lite.Optimize.DEFAULT]
tflite_model = converter.convert()

tflite_path = os.path.join(OUTPUT_DIR, 'plant_disease_model.tflite')
with open(tflite_path, 'wb') as f:
    f.write(tflite_model)

size_mb = os.path.getsize(tflite_path) / 1e6
print(f'TFLite model saved  -> {tflite_path}  ({size_mb:.1f} MB)')





